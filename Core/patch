cd $HOME/nekropol/Core
update(){
if wget --spider https://raw.githubusercontent.com/k3746ov/nekropol/main/update.v3.1>/dev/null; then
cd $HOME/nekropol/Core
rm *.txt
echo "nekropol" > patch.txt
else
clear
echo
echo
echo
sleep 3.0
cd $HOME/nekropol
bash install.sh
fi
}
update

option(){
if [ -f "$HOME/nekropol/Core/patch.txt" ];then
$dbox
else
echo
fi
}
option

dbox(){
clear
echo
echo
echo
echo
echo
echo
echo
echo -en "\e[32mSELECT OPTION [\e[93my/\e[93mt\e[32m]\e[96m: \e[0m "
read patcher
if [ $updater = y ];then
clear
sleep 0.5
cd $HOME
sleep 1
echo
echo
while git clone https://github.com/k3746ov/nekropol 2> /dev/null; do
sleep 1
done
echo
echo
echo
sleep 2.0
cd $HOME/nekropol
bash setup
elif [ $updater = t ];then
clear
sleep 1
cd $HOME/nekropol
bash install.sh
else
clear
echo
sleep 1
cd $HOME/nekropol
bash nekropol
echo
fi
}
dbox
